@if (!ApplicationService.SupportsKeybinds)
{
    return;
}

<KeybindEditorInternal Label="@Label"
                       Value="@Value"
                       ValueChanged="@KeyChanged" />

@using Sidekick.Common.Platform
@using Sidekick.Common.Settings

@inject IApplicationService ApplicationService
@inject ISettingsService SettingsService
@inject IKeyboardProvider KeyboardProvider

@code {

    [Parameter]
    public required string Label { get; set; }

    [Parameter]
    public required string DatabaseKey { get; set; }

    private string? Value { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Value = await SettingsService.GetString(DatabaseKey);
        await base.OnInitializedAsync();
    }

    private async Task KeyChanged(string? value)
    {
        if (KeyboardProvider.UsedKeybinds.Contains(value))
        {
            // set invalid
            return;
        }

        Value = value;
        await SettingsService.Set(DatabaseKey, value);
    }
}
